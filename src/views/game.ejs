<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<title>3D Pong</title>
		<script type="importmap">
			{
				"imports": {
					"three": "https://cdn.jsdelivr.net/npm/three@0.182.0/build/three.module.js",
					"three/addons/": "https://cdn.jsdelivr.net/npm/three@0.182.0/examples/jsm/"
				}
			}
		</script>
		<style>
			body {
				position: relative;
				margin: 0;
			}

			#chat {
				background: rgba(0, 0, 0, 25%);
				position: absolute;
				top: 0;
				left: 0;
				padding: 1rem;
			}

			#chat__text {
				font-family: sans-serif;
				margin: 0;
				color: white;
				font-size: 1.1rem;
				height: 10rem;
				width: 45ch;
				overflow-y: auto;
				white-space: pre-wrap;
			}

			#chat__box {
				width: 100%;
				background: transparent;
				color: white;
				border: 1px solid grey;
			}

			#lobby-info {
				position: absolute;
				left: 50%;
				right: 50%;
				bottom: 2rem;
				color: white;
				font-family: monospace;
				text-align: center;
				width: min-content;
				transform: translateX(-50%);
			}

			#waiting {
				position: fixed;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				background: radial-gradient(circle at center, rgba(0,0,0,0.6), rgba(0,0,0,0.85));
				font-family: sans-serif;
			}

			#waiting__card {
				position: relative;
				background: rgba(0, 0, 0, 0.4);
				border: 1px solid rgba(255, 255, 255, 0.15);
				border-radius: 12px;
				padding: 2rem;
				width: 45ch;
				backdrop-filter: blur(8px);
				box-shadow: 0 0 25px rgba(0, 0, 0, 0.6);
			}

			#waiting__title {
				margin: 0 0 1rem 0;
				color: white;
				font-size: 1.5rem;
				letter-spacing: 0.05em;
			}

			#waiting__players {
				margin: 0 0 1.5rem 0;
				color: white;
				font-size: 1.1rem;
				max-height: 10rem;
				overflow-y: auto;
			}

			#waiting__players span {
				display: block;
				padding: 0.25rem 0;
				border-bottom: 1px solid rgba(255,255,255,0.08);
			}

			#waiting__players span:last-child {
				border-bottom: none;
			}

			#waiting__escHint {
				position: absolute;
				top: 0.75rem;
				right: 0.75rem;
				color: rgba(255, 255, 255, 0.8);
				font-size: 0.8rem;
				font-family: monospace;
				letter-spacing: 0.02em;
			}

			#waiting__scoreboard {
				margin: 0 0 1rem 0;
				color: white;
				font-size: 1rem;
				line-height: 1.5;
			}

			#waiting__leaveButton {
				width: 100%;
				padding: 0.75rem;
				font-size: 1rem;
				border-radius: 8px;
				border: 1px solid rgba(255,255,255,0.2);
				background: rgba(235, 87, 87, 0.35);
				color: white;
				cursor: pointer;
				transition: all 0.2s ease;
			}

			#waiting__leaveButton:hover {
				background: rgba(235, 87, 87, 0.5);
				transform: translateY(-1px);
			}

			#waiting__leaveButton:active {
				transform: translateY(0);
			}

			#startButton {
				width: 100%;
				padding: 0.75rem;
				font-size: 1rem;
				border-radius: 8px;
				border: 1px solid rgba(255,255,255,0.2);
				background: rgba(255,255,255,0.1);
				color: white;
				cursor: pointer;
				transition: all 0.2s ease;
			}

			#startButton:hover:not(:disabled) {
				background: rgba(255,255,255,0.2);
				transform: translateY(-1px);
			}

			#startButton:active:not(:disabled) {
				transform: translateY(0);
			}

			#startButton:disabled {
				opacity: 0.4;
				cursor: not-allowed;
			}

			#escape-menu {
				position: fixed;
				inset: 0;
				display: none;
				align-items: center;
				justify-content: center;
				background: rgba(0, 0, 0, 0.55);
				font-family: sans-serif;
				z-index: 2000;
			}

			#escape-menu.is-open {
				display: flex;
			}

			#escape-menu__card {
				width: min(90vw, 360px);
				padding: 1.25rem;
				border-radius: 12px;
				background: rgba(18, 18, 18, 0.95);
				border: 1px solid rgba(255, 255, 255, 0.2);
				box-shadow: 0 12px 36px rgba(0, 0, 0, 0.45);
			}

			#escape-menu__title {
				margin: 0 0 0.75rem 0;
				color: white;
				font-size: 1.1rem;
			}

			#escape-menu__actions {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}

			.escape-menu__button {
				width: 100%;
				padding: 0.65rem 0.75rem;
				border-radius: 8px;
				border: 1px solid rgba(255, 255, 255, 0.2);
				background: rgba(255, 255, 255, 0.08);
				color: white;
				font-size: 0.95rem;
				cursor: pointer;
			}

			.escape-menu__button:hover {
				background: rgba(255, 255, 255, 0.18);
			}

			.escape-menu__button--danger {
				background: rgba(235, 87, 87, 0.32);
			}

			.escape-menu__button--danger:hover {
				background: rgba(235, 87, 87, 0.5);
			}
		</style>
	</head>
	<body>
		<div id="chat">
			<pre id="chat__text"></pre>
			<input id="chat__box" placeholder="Chat (press Enter)" />
		</div>

		<div id="waiting">
			<div id="waiting__card">
				<div id="waiting__escHint">Press [Esc] to exit lobby</div>
				<p id="waiting__title">Waiting for players...</p>
				<div id="waiting__players"></div>
				<div id="waiting__scoreboard" style="display: none"></div>
				<button id="startButton" disabled>Start Game</button>
				<button id="waiting__leaveButton" style="display: none">
					Leave Lobby
				</button>
			</div>
		</div>

		<div id="lobby-info">
			Join Code<br /><span style="font-size: 2rem"><%= code %></span>
		</div>

		<div id="escape-menu" aria-hidden="true">
			<div id="escape-menu__card" role="dialog" aria-modal="true" aria-labelledby="escape-menu__title">
				<h2 id="escape-menu__title">Menu</h2>
				<div id="escape-menu__actions">
					<button id="escape-menu__resume" class="escape-menu__button">Resume</button>
					<button id="escape-menu__exit" class="escape-menu__button escape-menu__button--danger">
						Exit Lobby
					</button>
				</div>
			</div>
		</div>
		<script type="module" src="/main.js"></script>
	</body>
</html>
